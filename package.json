{
  "name": "cafehaste-web",
  "private": true,
  "version": "2.3.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "prebuild": "node ../scripts/sync_version.js",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "lint": "tsc --noEmit",
    "find-deadcode": "ts-prune",
    "predeploy": "node ../scripts/sync_version.js",
    "deploy": "tsx scripts/deploy_runner.ts",
    "version:update": "node ../scripts/update_version.js",
    "tips:cli": "tsx ../cafehaste-etc/kakao/publish_tip.ts",
    "clean:orphans": "tsx server/cli/clean_orphaned_attachments.ts",
    "releases:archive": "tsx scripts/archive_releases.ts",
    "git:flatten": "tsx scripts/flatten_git.ts"
  },
  "dependencies": {
    "@google/genai": "^2.6.0",
    "@supabase/supabase-js": "^2.107.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "pg": "^8.21.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-react": "^5.0.0",
    "esbuild": "^0.28.0",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.553.0",
    "motion": "^12.40.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sharp": "^0.35.1",
    "three": "^0.181.1",
    "ts-prune": "^0.10.3",
    "tsx": "^4.22.3",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
